def optimized_bubble_sort(arr):
    arr = arr[:]   # Create a copy
    n = len(arr)
    passes = 0

    for i in range(n - 1):
        swapped = False
        passes += 1

        for j in range(n - i - 1):
            if arr[j] > arr[j + 1]:
                arr[j], arr[j + 1] = arr[j + 1], arr[j]
                swapped = True

        if not swapped:
            break

    return arr, passes


# -----------------------------
# Example Output
# -----------------------------
roll_numbers = [101,102,104,103,105,107,106,108]

print("Original Roll Numbers:", roll_numbers)

sorted_rolls, passes = optimized_bubble_sort(roll_numbers)

print("Sorted Roll Numbers:", sorted_rolls)
print("Number of Passes:", passes)

