sorted_rolls, passes = optimized_bubble_sort([101,102,104,103,105,107,106,108])
assert sorted_rolls == sorted([101,102,104,103,105,107,106,108])
assert passes < 8

sorted_ok, passes_ok = optimized_bubble_sort([1,2,3,4,5])
assert passes_ok == 1

