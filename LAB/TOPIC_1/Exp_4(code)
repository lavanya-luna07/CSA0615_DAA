def fibonacci_iterative(n):
    a, b = 0, 1
    series = []
    for _ in range(n):
        series.append(a)
        a, b = b, a + b
    return series

def fibonacci_recursive(n):
    if n <= 1:
        return n
    return fibonacci_recursive(n-1) + fibonacci_recursive(n-2)

n = 6

print("Iterative:", fibonacci_iterative(n))

print("Recursive:")
for i in range(n):
    print(fibonacci_recursive(i), end=" ")
